# Telegram bot token from BotFather
TELEGRAM_BOT_TOKEN=

# DeepSeek API key. The variable name is kept as OPENAI_API_KEY because DeepSeek uses an OpenAI-compatible API.
OPENAI_API_KEY=

# Optional defaults
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
MAX_CONTEXT_CHARS=6000
LOG_CHAT_ID=
